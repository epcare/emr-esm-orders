{
  "name": "@epcare/esm-medical-supply-orders-app",
  "version": "4.0.5",
  "description": "Medical Supply Orders app for the EMR",
  "browser": "dist/epcare-esm-medical-supply-orders-app.js",
  "main": "src/index.ts",
  "source": true,
  "license": "MPL-2.0",
  "homepage": "https://github.com/epcare/epcare-esm-orders#readme",
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development --config ../../rspack.config.js",
    "debug": "npm run serve",
    "build": "rspack --mode production --config ../../rspack.config.js",
    "analyze": "rspack --mode=production --env.analyze=true --config ../../rspack.config.js",
    "lint": "eslint src --ext ts,tsx",
    "typescript": "tsc",
    "extract-translations": "i18next 'src/**/*.component.tsx' 'src/**/*.workspace.tsx' 'src/**/*.modal.tsx' 'src/index.ts' --config ../../tools/i18next-parser.config.js",
    "test": "cross-env TZ=UTC vitest run --passWithNoTests",
    "test:watch": "cross-env TZ=UTC vitest watch",
    "coverage": "cross-env TZ=UTC vitest run --coverage --passWithNoTests"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/epcare/epcare-esm-orders#readme"
  },
  "bugs": {
    "url": "https://github.com/epcare/epcare-esm-orders/issues/issues"
  },
  "dependencies": {
    "@carbon/react": "^1.83.0",
    "lodash-es": "^4.17.21",
    "react-to-print": "^3.1.1"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "10.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "swr": "2.x"
  }
}
