{
  "name": "@epcare/esm-orders-app",
  "version": "4.0.5",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "ci:prepublish": "yarn workspaces foreach --all --topological --exclude @epcare/esm-orders-app npm publish --access public --tag next",
    "ci:publish": "yarn workspaces foreach --all --topological --exclude @epcare/esm-orders-app npm publish --access public --tag latest",
    "coverage": "yarn test --coverage",
    "preinstall": "node -e \"if(process.env.npm_execpath.indexOf('yarn') === -1) throw new Error('You must use Yarn to install dependencies')\"",
    "postinstall": "husky install",
    "prepare": "husky",
    "prettier": "prettier --config prettier.config.js --write \"packages/**/*.{ts,tsx,css,scss}\" \"e2e/**/*.ts\"",
    "release": "yarn workspaces foreach --all --topological version",
    "start": "openmrs develop --sources 'packages/esm-procedure-orders-app' 'packages/esm-medical-supply-order-app' 'packages/esm-imaging-orders-app'",
    "test-e2e": "playwright test",
    "test": "cross-env TZ=UTC vitest run --passWithNoTests",
    "test:watch": "cross-env TZ=UTC vitest watch",
    "typescript": "tsc",
    "verify": "turbo run lint && turbo run typescript && turbo run test --color --concurrency=5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --cache --fix"
  },
  "resolutions": {
    "sass": "^1.54.3"
  },
  "dependencies": {
    "@carbon/charts-react": "^1.13.33",
    "@hookform/resolvers": "^3.3.4",
    "classnames": "^2.5.1",
    "fuzzy": "^0.1.3",
    "react-hook-form": "^7.49.3",
    "ts-dotenv": "^0.9.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@carbon/pictograms-react": "^11.66.0",
    "@openmrs/esm-framework": "10.0.0",
    "@openmrs/esm-patient-common-lib": "10.0.0",
    "@playwright/test": "^1.53.2",
    "@swc/cli": "^0.1.57",
    "@swc/core": "^1.2.165",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.3.0",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/carbon__pictograms-react": "^11",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.0",
    "@types/webpack-env": "^1.18.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "axios": "^1.6.8",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "d3-selection": "^3.0.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.1",
    "dotenv-webpack": "^8.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-playwright": "^2.2.2",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-testing-library": "^7.13.1",
    "husky": "^9.1.6",
    "i18next": "^25.0.0",
    "i18next-parser": "^9.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^15.2.10",
    "lodash": "^4.17.21",
    "openmrs": "10.0.0",
    "pinst": "^3.0.0",
    "prettier": "^3.2.4",
    "pretty-quick": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.21.3",
    "rxjs": "^6.6.7",
    "sass": "^1.54.3",
    "swr": "2.2.5",
    "turbo": "^2.5.4",
    "typescript": "^5.0.0",
    "uuid": "^9.0.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "yarn@4.10.3",
  "prepare": "husky install"
}
